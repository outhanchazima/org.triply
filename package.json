{
  "name": "@org.triply/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "commit": "czg",
    "lint:staged": "lint-staged",
    "changelog": "changelogen",
    "start:all": "nx run-many -t serve --projects=triply.api,triply.payments --parallel",
    "start:triply.api": "nx serve triply.api",
    "start:triply.api:dev": "nx serve triply.api --watch",
    "start:triply.api:debug": "nx serve triply.api --inspect",
    "start:triply.api:prod": "node dist/apps/triply.api/main.js",
    "start:triply.payments": "nx serve triply.payments",
    "start:triply.payments:dev": "nx serve triply.payments --watch",
    "start:triply.payments:debug": "nx serve triply.payments --inspect",
    "start:triply.payments:prod": "node dist/apps/triply.payments/main.js",
    "build:all": "nx run-many -t build --projects=triply.api,triply.payments",
    "build:libs": "nx run-many -t build --projects=shared",
    "build:triply.api": "nx build triply.api",
    "build:triply.api:prod": "nx build triply.api --configuration=production",
    "build:triply.payments": "nx build triply.payments",
    "build:triply.payments:prod": "nx build triply.payments --configuration=production",
    "test:all": "nx run-many -t test --all",
    "test:affected": "nx affected -t test",
    "test:libs": "nx run-many -t test --projects=shared",
    "test:triply.api": "nx test triply.api",
    "test:triply.api:watch": "nx test triply.api --watch",
    "test:triply.api:coverage": "nx test triply.api --coverage",
    "test:triply.api:debug": "nx test triply.api --runInBand",
    "test:triply.payments": "nx test triply.payments",
    "test:triply.payments:watch": "nx test triply.payments --watch",
    "test:triply.payments:coverage": "nx test triply.payments --coverage",
    "e2e:triply.api": "nx e2e triply.api-e2e",
    "e2e:triply.api:prod": "nx e2e triply.api-e2e --configuration=production",
    "lint:all": "nx run-many -t lint --all",
    "lint:affected": "nx affected -t lint",
    "lint:libs": "nx run-many -t lint --projects=shared",
    "lint:triply.api": "nx lint triply.api",
    "lint:triply.api:fix": "nx lint triply.api --fix",
    "lint:triply.payments": "nx lint triply.payments",
    "lint:triply.payments:fix": "nx lint triply.payments --fix",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "format:write": "nx format:write",
    "format:affected": "nx format:write --uncommitted",
    "graph": "nx graph",
    "show:projects": "nx show projects",
    "show:triply.api": "nx show project triply.api",
    "show:triply.payments": "nx show project triply.payments",
    "show:shared": "nx show project shared",
    "dev:setup": "npm install && npm run build:libs",
    "dev:reset": "nx reset && npm install",
    "dev:clean": "rm -rf dist node_modules/.cache .nx/cache",
    "dev:fresh": "npm run dev:clean && npm install && npm run build:libs",
    "g:app": "nx generate @nx/nest:application",
    "g:lib": "nx generate @nx/nest:library",
    "g:module": "nx generate @nx/nest:module",
    "g:service": "nx generate @nx/nest:service",
    "g:controller": "nx generate @nx/nest:controller",
    "g:resource": "nx generate @nx/nest:resource",
    "infisical:setup": "infisical login && infisical init",
    "infisical:run": "infisical run --env=dev nx serve triply.api",
    "infisical:dev": "infisical run --env=dev -- nx serve triply.api",
    "infisical:build": "infisical run --env=prod -- nx build triply.api",
    "infisical:test": "infisical run --env=test -- nx test triply.api"
  },
  "private": true,
  "dependencies": {
    "@casl/ability": "^6.8.0",
    "@infisical/sdk": "^4.0.6",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.14",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.14",
    "@node-rs/bcrypt": "^1.10.7",
    "arkenv": "^0.11.0",
    "arktype": "^2.1.29",
    "axios": "^1.13.5",
    "bullmq": "^5.70.1",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "compression": "^1.8.1",
    "date-fns": "^4.1.0",
    "helmet": "^8.1.0",
    "mongoose": "^9.2.2",
    "otplib": "^13.3.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^9.39.3",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.14",
    "@nx/eslint": "22.5.2",
    "@nx/eslint-plugin": "22.5.2",
    "@nx/jest": "22.5.2",
    "@nx/js": "22.5.2",
    "@nx/nest": "22.5.2",
    "@nx/node": "22.5.2",
    "@nx/web": "22.5.2",
    "@nx/webpack": "22.5.2",
    "@nx/workspace": "22.5.2",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.13",
    "@swc/helpers": "0.5.19",
    "@swc/jest": "0.2.39",
    "@types/compression": "^1.8.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/qs": "^6.14.0",
    "changelogen": "^0.6.2",
    "czg": "^1.12.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-node": "^30.2.0",
    "jest-util": "^30.2.0",
    "jsonc-eslint-parser": "^3.1.0",
    "lint-staged": "^16.2.7",
    "nx": "22.5.2",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack-cli": "^6.0.1"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ]
}
