# ── Application ─────────────────────────────────────────
# Environment: development | sandbox | production | test
NODE_ENV=development

# Mode: sandbox | live
# sandbox = uses test API keys, Swagger enabled, verbose errors
# live    = uses production API keys, Swagger disabled, minimal errors
APP_MODE=sandbox

PORT=3000
API_PREFIX=api
API_VERSION=1.0.0

# ── CORS ────────────────────────────────────────────────
# Comma-separated origins, or '*' for all
CORS_ORIGINS=http://localhost:3000,http://localhost:4200

# ── Swagger ─────────────────────────────────────────────
SWAGGER_TITLE=Triply API
SWAGGER_DESCRIPTION=The Triply Travel Platform API
SWAGGER_VERSION=1.0

# ── Rate Limiting ───────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ── Amadeus API ─────────────────────────────────────────
# Sandbox: https://test.api.amadeus.com
# Live:    https://api.amadeus.com
AMADEUS_API_URL=https://test.api.amadeus.com
AMADEUS_API_KEY=your_amadeus_api_key
AMADEUS_API_SECRET=your_amadeus_api_secret
AMADEUS_APP_NAME=triply

# ── Database (optional) ────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/triply
MONGODB_URI=mongodb://localhost:27017/triply
REDIS_URL=redis://localhost:6379

# ── JWT (optional) ─────────────────────────────────────
JWT_SECRET=your_jwt_secret
JWT_EXPIRATION=3600
