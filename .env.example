# ── Application ─────────────────────────────────────────
# Environment: development | sandbox | production | test
NODE_ENV=development

# Mode: sandbox | live
# sandbox = uses test API keys, Swagger enabled, verbose errors
# live    = uses production API keys, Swagger disabled, minimal errors
APP_MODE=sandbox

PORT=3000
API_PREFIX=api
API_VERSION=1.0.0

# ── CORS ────────────────────────────────────────────────
# Comma-separated origins, or '*' for all
CORS_ORIGINS=http://localhost:3000,http://localhost:4200

# ── Swagger ─────────────────────────────────────────────
SWAGGER_TITLE=Triply API
SWAGGER_DESCRIPTION=The Triply Travel Platform API
SWAGGER_VERSION=1.0

# ── Rate Limiting ───────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ── Database ─────────────────────────────────────────────
# MongoDB connection string (required for auth module)
MONGODB_URI=mongodb://localhost:27017/triply

# Optional databases for other features
DATABASE_URL=postgresql://user:password@localhost:5432/triply
REDIS_URL=redis://localhost:6379

# ── JWT Authentication (required) ───────────────────────
# JWT secrets (use different secrets for access and refresh tokens)
JWT_SECRET=your-super-secret-jwt-access-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-jwt-refresh-key-change-this-in-production

# OTP
OTP_SECRET=your-super-secret-otp-key-change-this-in-production
OTP_PERIOD=300

# JWT expiration times
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Google OAuth (required for Google auth) ────────────
# Get these from Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ── Email Configuration (required for OTP/notifications) ──
# SMTP settings (Gmail example)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM=noreply@triply.com
MAIL_FROM_NAME=Triply

# ── Encryption (required for sensitive data) ────────────
# 32-byte key for AES-256-GCM encryption
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-encryption-key-hex-format

# ── Security Configuration ───────────────────────────────
# OTP configuration
OTP_EXPIRY_MINUTES=10
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30

# ── Logging Configuration ────────────────────────────────
LOG_LEVEL=info
LOG_ENABLE_FILE=true
LOG_DIR=./logs
LOG_MAX_FILE_SIZE=10485760
LOG_MAX_FILES=10
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_JSON=false
LOG_ENABLE_CORRELATION_ID=true
LOG_ENABLE_ASYNC=true
LOG_BUFFER_SIZE=1000
LOG_FLUSH_INTERVAL=5000

# ── Amadeus API ─────────────────────────────────────────
# Sandbox: https://test.api.amadeus.com
# Live:    https://api.amadeus.com
AMADEUS_API_URL=https://test.api.amadeus.com
AMADEUS_API_KEY=your_amadeus_api_key
AMADEUS_API_SECRET=your_amadeus_api_secret
AMADEUS_APP_NAME=triply

# ── Development/Testing ───────────────────────────────────
# For development only - disable in production
DEV_DISABLE_EMAIL=false
DEV_OTP_BYPASS=false
