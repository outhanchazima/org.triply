{
  "name": "@org.triply/shared",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "nx": {
    "name": "shared",
    "tags": [
      "type:lib",
      "scope:shared"
    ],
    "targets": {
      "build": {
        "executor": "@nx/js:tsc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "dist/libs/shared",
          "tsConfig": "libs/shared/tsconfig.lib.json",
          "packageJson": "libs/shared/package.json",
          "main": "libs/shared/src/index.ts",
          "assets": [
            "libs/shared/*.md"
          ]
        }
      }
    }
  },
  "dependencies": {
    "@casl/ability": "^6.8.0",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@org.triply/database": "0.0.1",
    "arkenv": "^0.11.0",
    "axios": "^1.13.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "date-fns": "^4.1.0",
    "express": "5.2.1",
    "form-data": "4.0.5",
    "mongoose": "^9.2.2",
    "otplib": "^13.3.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "qs": "6.15.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "ms": "2.1.3"
  }
}
